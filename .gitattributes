# Auto detect text files and normalize line endings to LF
* text=auto

# Git
.gitignore text eol=lf
.gitattributes text eol=lf

# JavaScript
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf

# Markdown
*.md text eol=lf

# Shell
*.sh text eol=lf eol=crlf
